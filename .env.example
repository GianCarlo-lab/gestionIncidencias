# Pide Servicio — Variables de entorno requeridas
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el archivo .env con valores reales.

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# Solo en Edge Functions / servidor (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Resend (correos transaccionales)
RESEND_API_KEY=re_tu-api-key

# Entorno
APP_ENV=development
APP_URL=http://localhost:3000
